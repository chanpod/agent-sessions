{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/v2/crates/tauri-cli/schema.json",
  "productName": "ToolChain",
  "identifier": "com.toolchain.app",
  "version": "2.1.6",
  "build": {
    "beforeBuildCommand": "pnpm build:frontend",
    "beforeDevCommand": "pnpm dev:frontend",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ToolChain",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGRTQ2MTg0MEFCOURCMUQKUldRZDI3a0toR0hrVDIySk1aNTdzeU9GL1JlWCtNWEovT0M3YmtUVmhrbUplcy9jM3gzSklscTYK",
      "endpoints": [
        "https://github.com/chanpod/agent-sessions/releases/latest/download/latest.json"
      ]
    }
  }
}
